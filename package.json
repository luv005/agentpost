{
  "name": "agentpost",
  "version": "0.1.0",
  "description": "Email infrastructure API for AI agents",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "seed": "tsx src/scripts/seed.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.750.0",
    "@aws-sdk/client-ses": "^3.750.0",
    "@aws-sdk/s3-request-presigner": "^3.750.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.0.0",
    "@fastify/sensible": "^6.0.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "bullmq": "^5.30.0",
    "drizzle-orm": "^0.38.0",
    "fastify": "^5.2.0",
    "google-auth-library": "^10.6.2",
    "ioredis": "^5.9.3",
    "js-yaml": "^4.1.1",
    "jsonwebtoken": "^9.0.3",
    "mailparser": "^3.9.4",
    "nanoid": "^5.0.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.0",
    "smtp-server": "^3.18.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.0.0",
    "@types/smtp-server": "^3.5.12",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
