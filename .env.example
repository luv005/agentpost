# Server
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://agentpost:agentpost@localhost:5432/agentpost

# Redis
REDIS_URL=redis://localhost:6379

# AWS SES
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_FROM_DOMAIN=agentsend.io
SES_DRY_RUN=true

# AWS S3
S3_BUCKET=agentpost-attachments
S3_REGION=us-east-1

# Rate Limiting
RATE_LIMIT_GLOBAL_MAX=100
RATE_LIMIT_GLOBAL_WINDOW_MS=60000
DEFAULT_INBOX_DAILY_LIMIT=10
VERIFIED_INBOX_DAILY_LIMIT=1000

# Anti-Abuse
MAX_BOUNCE_RATE=0.05
MAX_COMPLAINT_RATE=0.001
MAX_ATTACHMENT_SIZE_BYTES=10485760

# Email Queue
EMAIL_QUEUE_CONCURRENCY=5
EMAIL_QUEUE_MAX_RETRIES=3
EMAIL_QUEUE_RETRY_DELAY_MS=30000

# SMTP Inbound
SMTP_PORT=2525
SMTP_HOST=0.0.0.0
SMTP_MAX_SIZE=26214400

# Webhooks
WEBHOOK_MAX_RETRIES=5
WEBHOOK_RETRY_DELAY_MS=10000
WEBHOOK_TIMEOUT_MS=30000

# Auth
JWT_SECRET=change-me-in-production-please
JWT_EXPIRES_IN=7d
MAGIC_LINK_EXPIRES_MINUTES=15

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# App
APP_URL=http://localhost:3000
