{
  "name": "@agentsend/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for the AgentSend email API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
